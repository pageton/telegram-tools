		"gh-pages": "^6.3.0",
		"jsdom": "^29.1.1",
		"svelte": "^5.45.2",
		"svelte-check": "^4.3.4",
		"typescript": "~5.9.3",
		"vite": "^7.3.1",
		"vitest": "^4.1.5"
	},
	"dependencies": {
		"@mtcute/convert": "^0.28.1",
		"@mtcute/web": "^0.28.1",
		"@tailwindcss/vite": "^4.2.1",
		"big-integer": "^1.6.52",
		"lightningcss-linux-x64-gnu": "^1.31.1",
